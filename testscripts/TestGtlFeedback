    @patch('services.gtl.workflow.DatabaseManager')
    @patch('services.gtl.workflow.VectorInterface')

    def test_approve_and_replace_delivery_kit(self, mock_vector_interface, mock_db_manager):
        mock_vector_interface.return_value = MagicMock()
        mock_db = MagicMock()
        mock_db_manager.return_value = mock_db

        header = {'eventType': 'IP_RECOMMENDATION_UPDATE', 'eventSubType': 'APPROVE_AND_REPLACE_DELIVERY_KIT'}
        payload = {'ipId': 'IP1', 'daFileId': 'DA003', 'status': 'APPROVED', 'uuid': 'UUID1'}
        self.handler.handle(header, payload)
 
