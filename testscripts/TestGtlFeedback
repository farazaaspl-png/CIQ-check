import unittest
from unittest.mock import patch, MagicMock
import sys
import os
sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from kafka_framework.producer import KafkaMessageProducer
from services.gtl_feedback.handlers import GTLFeedbackHandler  # Adjust import path as needed
from core.exceptions import CustomBaseException
 
class TestGTLFeedbackHandler(unittest.TestCase):
 
    def setUp(self):
        producer = KafkaMessageProducer(
            bootstrap_servers='test_bootstrap',
            security_protocol='test_security_protocol',
            sasl_mechanism='test_sasl',
            sasl_plain_username='test_user',
            sasl_plain_password='test_pass'
        )
        self.handler = GTLFeedbackHandler(producer, 'test_output_topic')
 
    @patch('services.gtl.workflow.DatabaseManager')
    @patch('services.gtl.workflow.VectorInterface')

    def test_approve_document(self, mock_vector_interface, mock_db_manager):
        mock_vector = MagicMock()
        mock_vector_interface.return_value = mock_vector
        mock_db = MagicMock()
        mock_db_manager.return_value = mock_db

        header = {'eventType': 'IP_RECOMMENDATION_UPDATE', 'eventSubType': 'APPROVE_DOCUMENT'}
        payload = {'daFileId': 'DA001', 'status': 'APPROVED'}
        self.handler.handle(header, payload)
 
        mock_db.update_document.assert_called_with(
            where_clause={'dafileid': 'DA001'},
            update_values={'status': 'APPROVED'}
        )
        mock_vector.vectorize_documents_by_dafileids.assert_called_once_with(['DA001'])
 
