    @patch('services.gtl.workflow.DatabaseManager')

    def test_feedback_event(self, mock_db_manager):
        mock_db = MagicMock()
        mock_db_manager.return_value = mock_db

        header = {'eventType': 'IP_RECOMMENDATION_FEEDBACK'}
        payload = {'uuid': 'UUID2', 'filename': 'file.txt', 'daFileId': 'DA006', 'status': 'FEEDBACK_RECEIVED', 'feedback': 'Great'}
        self.handler.handle(header, payload)

        mock_db.update_document.assert_called_with(
            where_clause={'dafileid': 'DA006'},
            update_values={'status': 'FEEDBACK_RECEIVED'}
        )

        mock_db.insert_feedback.assert_called_with(
            msguuid='UUID2',
